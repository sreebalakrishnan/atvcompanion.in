# ATV Companion — environment variables
# Copy to .env for local dev (.env is gitignored). On Vercel, set these in
# Project Settings → Environment Variables.

# Supabase Postgres connection string (Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Supabase project URL + anon/public key (Project Settings → API)
SUPABASE_URL=https://[REF].supabase.co
SUPABASE_ANON_KEY=eyJ...

# Comma-separated emails that are auto-promoted to the admin role on first sign-in.
ADMIN_EMAILS=gnuyoga@gmail.com

# Local dev port (ignored on Vercel)
PORT=8000
