# macOS
.DS_Store
.AppleDouble
.LSOverride

# iCloud Drive sync-conflict copies (the "filename 2.ext" pattern)
# iCloud creates these when there's a sync race. They're byte-identical
# duplicates of the canonical file and should never be tracked.
* 2.html
* 2.json
* 2.txt
* 2.md
* 2.pdf
* 2.jpg
* 2.jpeg
* 2.png
* 2.gif
* 2.docx
* 2.xlsx
* 2.pptx
* 2.csv
* 2.svg
* 2.html\ *
* 2.zip

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local env / secrets
.env
.env.local
.env.*.local

# Node
node_modules/
.vercel/

# OS thumbnails
Thumbs.db
ehthumbs.db
Desktop.ini

# Temp
*.tmp

